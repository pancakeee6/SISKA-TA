# ==============================================================================
# KONFIGURASI DATABASE & ENVIRONMENT SISKA BACKEND
# ==============================================================================
# Salin file ini menjadi ".env" di dalam folder "backend/" dan sesuaikan isinya.

# 1. KONEKSI DATABASE
# - Untuk PostgreSQL Lokal:
#   DATABASE_URL="postgresql+asyncpg://postgres:password_anda@localhost:5432/siska"
#
# - Untuk Cloud Database (Aiven for PostgreSQL / Supabase / Neon):
#   Catatan: Jika dari Aiven dapat URI berawalan "postgres://", backend SISKA sudah 
#   mengonversinya secara otomatis ke format "postgresql+asyncpg://".
#   DATABASE_URL="postgres://avnadmin:password_anda@pg-xxxx.aivencloud.com:19853/defaultdb?sslmode=require"

# 2. KREDENSIAL ADMIN DEFAULT
ML_ADMIN_USERNAME="admin"
ML_ADMIN_PASSWORD="admin"
